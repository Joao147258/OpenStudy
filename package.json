{
  "name": "openstudy",
  "version": "1.0.0",
  "description": "OpenStudy — plugin de estudo híbrido para OpenCode. Ensina Go, C#, TypeScript e NestJS usando modelo local (DeepSeek R1 via Ollama) para gerar conteúdo didático com analogias cruzadas e modelo cloud para decidir estratégia pedagógica",
  "main": "estudo/estudo.ts",
  "types": "estudo/estudo.d.ts",
  "exports": {
    ".": "./estudo/estudo.ts"
  },
  "files": [
    "filosofia.ts",
    "filosofia.md",
    "estudo/estudo.ts",
    "estudo/perfil.json",
    "estudo/referencias/*.md"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "openstudy",
    "estudo",
    "aprendizado",
    "educacao",
    "deepseek",
    "ollama",
    "local-llm",
    "typescript",
    "nestjs",
    "csharp",
    "golang",
    "mentor",
    "didatica"
  ],
  "author": {
    "name": "Joao Dantas",
    "url": "https://github.com/Joao147258"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Joao147258/OpenStudy"
  },
  "bugs": {
    "url": "https://github.com/Joao147258/OpenStudy/issues"
  },
  "homepage": "https://github.com/Joao147258/OpenStudy#readme",
  "dependencies": {
    "@opencode-ai/plugin": "*",
    "@opencode-ai/sdk": "*"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check": "tsc --noEmit --strict"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
